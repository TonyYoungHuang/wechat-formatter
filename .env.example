API_PORT=3001
AUTH_SECRET=replace-with-a-long-random-secret
NODE_ENV=development
DATABASE_PATH=server/data/app.sqlite
ALLOW_MOCK_PAYMENTS=true
ADMIN_API_KEY=replace-with-an-admin-only-secret
SESSION_TTL_DAYS=7
SESSION_COOKIE_NAME=formatter_session
CORS_ORIGINS=https://paibanmao.cn,https://www.paibanmao.cn,https://api.paibanmao.cn

# Shared callback base URL. In production this must be an externally reachable HTTPS domain.
PAYMENT_NOTIFY_BASE_URL=https://api.paibanmao.cn
PAYMENT_HTTP_TIMEOUT_MS=12000

# WeChat Pay Native
# Live onboarding currently waits for ICP approval, then fill the values below.
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_MCH_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PLATFORM_CERT_SERIAL=
WECHAT_PAY_PLATFORM_CERT_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# Optional: provide the platform public key directly instead of a certificate.
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PEM=
WECHAT_PAY_NOTIFY_BASE_URL=

# Alipay Precreate
# Live onboarding currently waits for ICP approval, then fill the values below.
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
ALIPAY_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
ALIPAY_NOTIFY_BASE_URL=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# JiMeng / Volcengine image generation
AI_IMAGE_PROVIDER=tencent-hunyuan
TENCENT_HUNYUAN_SECRET_ID=
TENCENT_HUNYUAN_SECRET_KEY=
TENCENT_HUNYUAN_SESSION_TOKEN=
TENCENT_HUNYUAN_IMAGE_ENDPOINT=https://hunyuan.tencentcloudapi.com
TENCENT_HUNYUAN_REGION=ap-guangzhou
TENCENT_HUNYUAN_IMAGE_STYLE=201
TENCENT_HUNYUAN_IMAGE_SIZE=1024:1024
TENCENT_HUNYUAN_IMAGE_LOGO_ADD=0

# Reserved provider, kept in codebase but not enabled for launch by default
JIMENG_API_KEY=
JIMENG_API_URL=https://operator.las.cn-beijing.volces.com/api/v1/online/images/generations
JIMENG_IMAGE_MODEL=doubao-seedream-3-0-t2i-250415
JIMENG_IMAGE_SIZE=2K
JIMENG_IMAGE_WATERMARK=true
AI_IMAGE_TIMEOUT_MS=20000
AI_IMAGE_MAX_RETRIES=1
